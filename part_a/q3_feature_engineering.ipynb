
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler, OneHotEncoder
from sklearn.compose import ColumnTransformer
from sklearn.pipeline import Pipeline
from sklearn.linear_model import LinearRegression
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_squared_error, mean_absolute_error

sns.set_theme(style="whitegrid")

df_retail = pd.read_csv('../data/q3_retail_promotions.csv')


df_retail['transaction_date'] = pd.to_datetime(df_retail['transaction_date'])

df_retail['year'] = df_retail['transaction_date'].dt.year
df_retail['month'] = df_retail['transaction_date'].dt.month
df_retail['day_of_week'] = df_retail['transaction_date'].dt.dayofweek # Monday=0, Sunday=6
df_retail['day_of_month'] = df_retail['transaction_date'].dt.day

df_retail['is_month_end'] = (df_retail['day_of_month'] >= 25).astype(int)


df_retail = df_retail.drop(columns=['day_of_month'])

print("Feature engineering complete. Sample of new columns:")
display(df_retail[['transaction_date', 'year', 'month', 'day_of_week', 'is_month_end']].sample(5))

#task 2:

df_retail = df_retail.sort_values('transaction_date').reset_index(drop=True)

X = df_retail.drop(columns=['items_sold', 'transaction_date', 'store_id'])
y = df_retail['items_sold']

split_idx = int(len(df_retail) * 0.8)

X_train = X.iloc[:split_idx]
X_test = X.iloc[split_idx:]
y_train = y.iloc[:split_idx]
y_test = y.iloc[split_idx:]

print(f"Training set size: {len(X_train)}")
print(f"Testing set size: {len(X_test)}")

#task 3

cat_features = ['promotion_type', 'location_type', 'store_size']
num_features = ['year', 'month', 'day_of_week', 'is_weekend', 'is_festival', 'competition_density', 'is_month_end']

preprocessor = ColumnTransformer(
    transformers=[
        ('cat', OneHotEncoder(handle_unknown='ignore'), cat_features),
        ('num', StandardScaler(), num_features)
    ])

print("Preprocessing pipeline defined.")

#task 4


models = {
    "Linear Regression": LinearRegression(),
    "Random Forest": RandomForestRegressor(n_estimators=100, random_state=42)
}

results = {}

for name, model in models.items():
    # Create and fit pipeline
    full_pipeline = Pipeline(steps=[
        ('preprocessor', preprocessor),
        ('regressor', model)
    ])
    
    full_pipeline.fit(X_train, y_train)
    y_pred = full_pipeline.predict(X_test)
    
  
    rmse = np.sqrt(mean_squared_error(y_test, y_pred))
    mae = mean_absolute_error(y_test, y_pred)
    results[name] = {'rmse': rmse, 'mae': mae, 'model': full_pipeline, 'preds': y_pred}
    
    print(f"\n--- {name} Performance ---")
    print(f"RMSE: {rmse:.2f}")
    print(f"MAE: {mae:.2f}")


fig, axes = plt.subplots(1, 2, figsize=(15, 6))
for i, (name, res) in enumerate(results.items()):
    axes[i].scatter(y_test, res['preds'], alpha=0.5)
    axes[i].plot([y_test.min(), y_test.max()], [y_test.min(), y_test.max()], 'r--', lw=2)
    axes[i].set_title(f'Parity Plot: {name}')
    axes[i].set_xlabel('Actual Items Sold')
    axes[i].set_ylabel('Predicted Items Sold')
plt.tight_layout()
plt.show()

