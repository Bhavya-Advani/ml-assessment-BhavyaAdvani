
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA

sns.set_theme(style="whitegrid")

#task 1

df_customers = pd.read_csv('../data/q2_customers.csv')

scaler = StandardScaler()
df_scaled = pd.DataFrame(scaler.fit_transform(df_customers), columns=df_customers.columns)

print("Data scaled successfully. First 5 rows of scaled data:")
display(df_scaled.head())

#task 2

wcss = []
K_range = range(1, 11)

for k in K_range:
    kmeans = KMeans(n_clusters=k, init='k-means++', random_state=42, n_init=10)
    kmeans.fit(df_scaled)
    wcss.append(kmeans.inertia_)

plt.figure(figsize=(10, 6))
plt.plot(K_range, wcss, marker='o', linestyle='--', color='b')
plt.title('Elbow Method for Optimal K')
plt.xlabel('Number of Clusters (K)')
plt.ylabel('Within-Cluster Sum of Squares (WCSS)')
plt.xticks(K_range)
plt.grid(True)
plt.show()

#task 3


optimal_k = 3
kmeans = KMeans(n_clusters=optimal_k, init='k-means++', random_state=42, n_init=10)
df_customers['cluster'] = kmeans.fit_predict(df_scaled)

centroids = df_customers.groupby('cluster').mean()
print("Cluster Centroids (Readable Dataframe):")
display(centroids)

#task 4


pca = PCA(n_components=2)
pc_data = pca.fit_transform(df_scaled)

print(f"Explained Variance Ratio: {pca.explained_variance_ratio_}")

loadings = pd.DataFrame(
    pca.components_.T, 
    columns=['PC1', 'PC2'], 
    index=df_customers.columns[:-1] # exclude the 'cluster' column
)
print("\nFeature Loadings:")
display(loadings)


df_pca = pd.DataFrame(data=pc_data, columns=['PC1', 'PC2'])
df_pca['cluster'] = df_customers['cluster']


plt.figure(figsize=(12, 8))
sns.scatterplot(
    data=df_pca, x='PC1', y='PC2', hue='cluster', 
    palette='bright', s=100, alpha=0.7
)
plt.title('Customer Segments Visualized via PCA (PC1 vs PC2)')
plt.xlabel('Principal Component 1 (Customer Value)')
plt.ylabel('Principal Component 2 (Recency)')
plt.legend(title='Customer Cluster')
plt.show()
