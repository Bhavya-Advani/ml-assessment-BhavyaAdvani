
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split, GridSearchCV
from sklearn.preprocessing import StandardScaler, OneHotEncoder
from sklearn.compose import ColumnTransformer
from sklearn.pipeline import Pipeline
from sklearn.impute import SimpleImputer
from sklearn.tree import DecisionTreeClassifier
from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier
from sklearn.metrics import confusion_matrix, classification_report, accuracy_score

sns.set_theme(style="whitegrid")

df = pd.read_csv('../data/q1_heart_disease.csv')

#task1
print(f"Dataset Shape: {df.shape}")
print("\nData Types:\n", df.dtypes)
print("\nMissing Values:\n", df.isnull().sum())

df.head()

#task2

plt.figure(figsize=(6, 4))
sns.countplot(x='heart_disease', data=df, palette='viridis')
plt.title('Distribution of Heart Disease (Target)')
plt.show()

plt.figure(figsize=(10, 8))
numeric_df = df.select_dtypes(include=[np.number])
sns.heatmap(numeric_df.corr(), annot=True, cmap='coolwarm', fmt=".2f")
plt.title('Correlation Heatmap of Numeric Features')
plt.show()

plt.figure(figsize=(8, 5))
sns.boxplot(x='heart_disease', y='age', data=df)
plt.title('Age Distribution by Heart Disease Status')
plt.show()


#Task3

categorical_features = ['chest_pain_type', 'resting_ecg', 'st_slope']
numerical_features = ['age', 'sex', 'resting_bp', 'cholesterol', 'fasting_bs', 'max_hr', 'exercise_angina', 'oldpeak']

# Strategy: Median imputation for numerical (handles outliers), One-Hot for categorical
num_transformer = Pipeline(steps=[
    ('imputer', SimpleImputer(strategy='median')),
    ('scaler', StandardScaler())
])

cat_transformer = Pipeline(steps=[
    ('onehot', OneHotEncoder(handle_unknown='ignore'))
])

preprocessor = ColumnTransformer(
    transformers=[
        ('num', num_transformer, numerical_features),
        ('cat', cat_transformer, categorical_features)
    ])

X = df.drop('heart_disease', axis=1)
y = df['heart_disease']

X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, stratify=y, random_state=42)

X_train_proc = preprocessor.fit_transform(X_train)
X_test_proc = preprocessor.transform(X_test)

print("Preprocessing complete. Training set shape:", X_train_proc.shape)

#task4 and 5

models = {
    "Decision Tree": DecisionTreeClassifier(random_state=42),
    "Random Forest": RandomForestClassifier(random_state=42),
    "Gradient Boosting": GradientBoostingClassifier(random_state=42)
}

for name, model in models.items():
    model.fit(X_train_proc, y_train)
    y_pred = model.predict(X_test_proc)
    
    print(f"\n--- {name} ---")
    print("Confusion Matrix:")
    print(confusion_matrix(y_test, y_pred))
    print("\nClassification Report:")
    print(classification_report(y_test, y_pred))

#conclusion task 5
Among the three classification models, Random Forest performed best on the test set, achieving the highest F1-score and overall balanced precision-recall performance.

- Decision Tree showed weaker generalization and lower predictive stability.
- Gradient Boosting performed competitively but slightly below Random Forest.
- Random Forest demonstrated the strongest ability to correctly classify both heart disease presence and absence.

Therefore, Random Forest was selected as the best-performing model for further hyperparameter tuning.

#task 6


param_grid = {
    'n_estimators': [50, 100],
    'learning_rate': [0.05, 0.1],
    'max_depth': [3, 4]
}

grid_search = GridSearchCV(GradientBoostingClassifier(random_state=42), param_grid, cv=5, scoring='f1')
grid_search.fit(X_train_proc, y_train)

print("Best Parameters:", grid_search.best_params_)

tuned_pred = grid_search.best_estimator_.predict(X_test_proc)
print("\nTuned Model Performance:")
print(classification_report(y_test, tuned_pred))
